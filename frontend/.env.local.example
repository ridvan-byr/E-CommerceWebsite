# REVIEW [F2] frontend/src/lib/firebase.ts dosyası 7 farklı NEXT_PUBLIC_FIREBASE_*
# environment variable'ı bekliyor; biri eksikse uygulama başlamadan hata fırlatıyor.
# Yeni bir geliştirici hangi env var'ları doldurması gerektiğini bilmek için
# kaynak kodunu okumak zorunda kalıyor. Bu .env.local.example dosyası şu işe yarar:
#
#   1. Hangi env var'ların gerektiğini tek bakışta gösterir
#   2. Açıklayıcı yorum satırları ile her birinin nereden alınacağını söyler
#   3. cp .env.local.example .env.local ile yeni geliştirici 30 saniyede başlar
#
# .env.local zaten .gitignore'da (gerçek değerler asla commit'lenmez), ama
# .env.local.example commit'lenir — örnek/şablon olarak.
#
# Kural: secret veya kullanıcıya özel değer asla example dosyaya yazılmaz;
# sadece anahtar adları ve "buraya ne yazılacak" notu olur.

# Backend API URL — backend default 5288'de dinler
NEXT_PUBLIC_API_URL=http://localhost:5288

# Firebase Authentication config
# Firebase Console → Project Settings → General → Web app → Config
# Bu değerler "public" — frontend bundle'ında zaten görünüyor olacak;
# Firebase API key'i secret değildir (auth domain + project ID ile birlikte
# kullanılır, gerçek güvenlik Firebase Security Rules ile sağlanır).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
